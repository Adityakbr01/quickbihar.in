{
  "expo": {
    "name": "QuickBihar",
    "slug": "QuickBihar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/QuickBihar_Icon_1024.png",
    "scheme": "QuickBihar",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.adityakbr.mobile"
    },
    "android": {
      "package": "com.adityakbr.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0f0f0f",
          "image": "./assets/images/QuickBihar_Wordmark.png",
          "imageWidth": 190,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#0f0f0f"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "c41a890a-b542-40e8-a2c3-d5d51814767d"
      }
    }
  }
}
