{
  "expo": {
    "name": "QuickBihar",
    "slug": "QuickBihar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icons/ios-icon-default.png",
    "scheme": "QuickBihar",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.adityakbr.mobile",
      "icon": "./assets/images/icons/ios-icon-default.png",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "package": "com.adityakbr.mobile",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icons/android-icon-foreground.png",
        "backgroundImage": "./assets/images/icons/android-icon-background.png",
        "monochromeImage": "./assets/images/icons/android-icon-monochrome.png",
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0f0f0f",
          "image": "./assets/images/icons/splash-icon.png",
          "imageWidth": 190,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#0f0f0f",
            "image": "./assets/images/icons/splash-icon.png"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-secure-store",
      "expo-font",
      "expo-web-browser",
      "expo-image",
      "expo-status-bar",
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "c41a890a-b542-40e8-a2c3-d5d51814767d"
      }
    }
  }
}
